# =========================================================================
# Spotify Playlist Vibe Splitter & Analyzer - Docker Environment Template
# =========================================================================
# Copy this file to a file named '.env' in the root directory,
# or paste these variables into your Portainer stack configuration.

# -------------------------------------------------------------------------
# 1. Spotify Application Credentials (Required)
# -------------------------------------------------------------------------
# Register your application at: https://developer.spotify.com/dashboard
# Make sure to register the matching Redirect URI in the Spotify Dashboard!
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# The port you'll use to access the frontend container locally
FRONTEND_PORT=8080

# The OAuth redirect callback URL (MUST match the FRONTEND_PORT above)
SPOTIFY_REDIRECT_URI=http://localhost:8080/callback

# -------------------------------------------------------------------------
# 2. Audio Features API (Optional)
# -------------------------------------------------------------------------
# Get your ReccoBeats API key at: https://reccobeats.com
# If omitted, the backend will generate realistic mock data for testing.
RECCOBEATS_API_KEY=your_reccobeats_api_key_here

# -------------------------------------------------------------------------
# 3. LLM AI Integration (Optional)
# -------------------------------------------------------------------------
# Select LLM Provider: gemini, openai, anthropic, lm_studio, or ollama
# If omitted, the engine will use rules-based playlist recommendations.
LLM_PROVIDER=

# Specify target model (e.g., gpt-4o-mini, gemini-1.5-flash, llama-3.2-3b)
LLM_MODEL=

# Cloud LLM Provider API Keys (Fill in based on LLM_PROVIDER choice)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# -------------------------------------------------------------------------
# 4. Advanced / Docker Config
# -------------------------------------------------------------------------
# CORS configuration - default '*' is safe for typical Docker deployments
CORS_ALLOWED_ORIGINS=*
# Optional: Set VITE_API_BASE_URL only if backend is hosted on a separate domain/IP
VITE_API_BASE_URL=
